---
import Base from "@layouts/Base.astro";
import { getScheduleData, formatEventTime } from "@data/schedule";
import { site } from "@data/site";

const { events, speakerMap } = await getScheduleData();

const fmt = formatEventTime;
const title = (e: (typeof events)[number]) => e.title ?? e.label ?? "";
const speakerNames = (e: (typeof events)[number]) =>
  e.speakerIds
    ?.map((id) => speakerMap[id]?.name)
    .filter(Boolean)
    .join(", ") ?? "";
---

<Base
  title={`Compact Agenda | ${site.pageTitle}`}
  description={`Compact day-of agenda for ${site.pageTitle}.`}
>
  <div id="page" class="min-h-screen">
    <header class="sticky top-0 z-10 grid grid-cols-[2.5rem_1fr_2.5rem] items-center gap-2 border-b backdrop-blur-md px-4 md:px-8 py-3">
      <h1 class="m-0 font-mono text-lg md:text-2xl leading-tight text-center col-start-2">
        Compact Agenda — {site.pageTitle}
      </h1>
      <button
        id="theme-toggle"
        type="button"
        aria-label="Switch to dark mode"
        class="inline-flex items-center justify-center w-10 h-10 p-0 border border-primary rounded-full text-primary cursor-pointer col-start-3"
      >
        <img id="icon-sun" src="/icons/theme-sun.svg" alt="" aria-hidden="true" width="18" height="18" />
        <img id="icon-moon" src="/icons/theme-moon.svg" alt="" aria-hidden="true" width="18" height="18" />
      </button>
    </header>

    <div class="max-w-4xl mx-auto px-4 md:px-8 pt-5 pb-24">
      {events.length === 0 && <p class="text-center">Agenda will be announced soon.</p>}
      <ol id="agenda-list" class="list-none grid gap-2 m-0 p-0">
        {events.map((event, i) => {
          const speakers = speakerNames(event);
          const t = title(event);
          return (
            <li
              data-index={i}
              data-when={event.when ?? ""}
              data-until={event.until ?? ""}
              class="agenda-item grid grid-cols-[minmax(3.6rem,auto)_minmax(0,1fr)_auto] grid-rows-[auto_auto] items-start gap-x-2 md:gap-x-3 rounded-lg border px-3 md:px-3 py-3 md:py-2"
            >
              <span class="time font-mono text-xs md:text-xs font-medium leading-tight whitespace-nowrap col-start-1 row-start-1">
                {event.when ? fmt(event.when) : ""}
              </span>

              <div class="content min-w-0 col-[1/-1] row-start-2">
                {speakers && (
                  <span class="block text-[11px] leading-tight opacity-70 overflow-anywhere mb-1">
                    {speakers}
                  </span>
                )}
                <span class="block font-mono text-[13px] font-medium leading-snug overflow-anywhere">
                  {t}
                </span>
              </div>

              <span class="badge items-center justify-center min-w-12 md:min-w-14 font-mono text-[.9rem] font-medium leading-none uppercase py-[.2rem] px-[.45rem] rounded-full col-start-3 row-start-1">
              </span>
            </li>
          );
        })}
      </ol>
    </div>

    <a
      id="home-button"
      href="/"
      aria-label="Go to home page"
      class="btn-lift fixed right-4 md:right-6 bottom-4 md:bottom-6 z-10 inline-flex items-center justify-center w-16 h-16 border border-primary rounded-full text-primary shadow-lg"
    >
      <img src="/icons/home.svg" alt="" aria-hidden="true" width="21" height="21" />
    </a>
  </div>
</Base>

<style>
  #page {
    --bg: #fffaf9;
    --fg: #464444;
    --header-bg: rgba(255, 250, 249, 0.94);
    --header-border: #f2d1cd;
    --item-border: #eee;
    --item-bg: white;
    --toggle-bg: white;
    --next-bg: #fff4f2;
    --glow-opacity: 0.75;
    background-color: var(--bg);
    color: var(--fg);
  }
  #page.dark {
    --bg: #161313;
    --fg: #f8ebe8;
    --header-bg: rgba(22, 19, 19, 0.94);
    --header-border: #3a2725;
    --item-border: #3a2725;
    --item-bg: #201817;
    --toggle-bg: #241b1a;
    --next-bg: #2c1d1b;
    --glow-opacity: 0.9;
  }

  #page header {
    background-color: var(--header-bg);
    border-bottom-color: var(--header-border);
  }
  #page header h1 {
    color: var(--fg);
  }
  #theme-toggle,
  #home-button {
    background-color: var(--toggle-bg);
  }

  #icon-sun {
    display: none;
  }
  #page.dark #icon-sun {
    display: block;
  }
  #page.dark #icon-moon {
    display: none;
  }

  .agenda-item {
    border-color: var(--item-border);
    background-color: var(--item-bg);
    color: var(--fg);
  }
  .agenda-item .time {
    color: var(--color-primary);
  }
  .agenda-item .badge {
    display: none;
  }

  .agenda-item.is-next {
    border-color: var(--color-primary);
    background-color: var(--next-bg);
  }
  .agenda-item.is-next .badge {
    display: flex;
    background-color: var(--color-primary);
    color: white;
  }

  .agenda-item.is-current {
    border-color: var(--color-primary);
    background-color: var(--color-primary);
    color: white;
    box-shadow: 0 0.8rem 2.4rem -1.6rem rgba(237, 67, 55, var(--glow-opacity));
  }
  .agenda-item.is-current .time {
    color: white;
  }
  .agenda-item.is-current .badge {
    display: flex;
    background-color: white;
    color: var(--color-primary);
  }
</style>

<script>
  const page = document.getElementById("page")!;
  const list = document.getElementById("agenda-list")!;
  const toggleBtn = document.getElementById("theme-toggle")!;
  const STORAGE_KEY = "compact-agenda-color-mode";

  type Mode = "light" | "dark";

  function getInitialMode(): Mode {
    const stored = localStorage.getItem(STORAGE_KEY);
    if (stored === "dark" || stored === "light") return stored;
    return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
  }

  function applyMode(mode: Mode) {
    const dark = mode === "dark";
    page.classList.toggle("dark", dark);
    toggleBtn.setAttribute("aria-label", dark ? "Switch to light mode" : "Switch to dark mode");
  }

  let mode = getInitialMode();
  applyMode(mode);

  toggleBtn.addEventListener("click", () => {
    mode = mode === "dark" ? "light" : "dark";
    localStorage.setItem(STORAGE_KEY, mode);
    applyMode(mode);
  });

  // Parse highlightTime param once; fall back to real clock per tick
  const fixedTime: number | null = (() => {
    const param = new URLSearchParams(window.location.search).get("highlightTime");
    if (!param) return null;
    const normalised = param.match(/^\d{4}-\d{2}-\d{2} \d{2}:\d{2}$/)
      ? param.replace(" ", "T")
      : param.replace(/ (\d{2}:\d{2})$/, "+$1");
    const ms = new Date(normalised).getTime();
    return isNaN(ms) ? null : ms;
  })();

  const items = Array.from(list.querySelectorAll<HTMLElement>(".agenda-item"));

  // Pre-compute timestamps so highlight() doesn't parse strings on every tick
  const timestamps = items.map((el) => {
    const w = el.dataset.when;
    const u = el.dataset.until;
    return {
      start: w ? new Date(w).getTime() : null,
      end: u ? new Date(u).getTime() : null,
    };
  });

  function highlight() {
    const now = fixedTime ?? Date.now();

    let currentIdx: number | null = null;
    let nextIdx: number | null = null;

    for (let i = 0; i < items.length; i++) {
      const { start, end: endRaw } = timestamps[i];
      if (start === null) continue;
      const end = endRaw ?? start;
      if (start <= now && now < end && currentIdx === null) currentIdx = i;
      if (start > now && nextIdx === null) nextIdx = i;
    }

    items.forEach((el, i) => {
      const isCurrent = i === currentIdx;
      const isNext = i === nextIdx;
      el.classList.toggle("is-current", isCurrent);
      el.classList.toggle("is-next", isNext);

      if (isCurrent || isNext) {
        const badge = el.querySelector<HTMLElement>(".badge")!;
        badge.textContent = isCurrent ? "Now" : "Next";
      }
    });

    if (!window.__agendaScrolled) {
      const idx = currentIdx ?? nextIdx;
      if (idx !== null) {
        window.__agendaScrolled = true;
        requestAnimationFrame(() => {
          items[idx]?.scrollIntoView({ block: "center" });
        });
      }
    }
  }

  declare global {
    interface Window { __agendaScrolled?: boolean; }
  }

  highlight();

  // Align first tick to next minute boundary, then every 60s
  const msToNextMinute = 60_000 - (Date.now() % 60_000);
  setTimeout(() => {
    highlight();
    setInterval(highlight, 60_000);
  }, msToNextMinute);
</script>
