---
import Base from "@layouts/Base.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import { site } from "@data/site";
import Content from "@prose/terms-of-service.mdx";
---

<Base
  title={`Terms of Service | ${site.pageTitle}`}
  description="Terms of Service for Warsaw Python Pizza tickets and attendance."
  noindex
>
  <Header />
  <main class="section-sm text-left pt-32">
    <h1 class="section-heading">Terms of Service</h1>
    <div class="prose-content [&_strong]:font-medium">
      <Content />
    </div>
  </main>
  <Footer />
</Base>
