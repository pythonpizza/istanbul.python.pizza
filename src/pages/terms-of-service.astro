---
import Base from "@layouts/Base.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Prose from "@components/Prose.astro";
import { site } from "@data/site";
import Content from "@prose/terms-of-service.mdx";
---

<Base
  title={`Terms of Service | ${site.pageTitle}`}
  description={`Terms of Service for ${site.pageTitle} tickets and attendance.`}
  noindex
>
  <Header />
  <main class="section-sm text-left pt-32">
    <h1 class="section-heading">Terms of Service</h1>
    <Prose class="[&_strong]:font-medium">
      <Content />
    </Prose>
  </main>
  <Footer />
</Base>
