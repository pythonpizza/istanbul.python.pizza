---
import Base from "@layouts/Base.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import { site } from "@data/site";
import Content from "@prose/privacy-policy.mdx";
---

<Base
  title={`Privacy Policy | ${site.pageTitle}`}
  description="Privacy Policy for Warsaw Python Pizza."
  noindex
>
  <Header />
  <main class="section-sm text-left pt-32">
    <h1 class="section-heading">Privacy Policy</h1>
    <div class="prose-content [&_strong]:font-medium">
      <Content />
    </div>
  </main>
  <Footer />
</Base>
