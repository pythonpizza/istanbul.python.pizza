---
import AnchorHeading from "@components/AnchorHeading.astro";
import CtaButton from "@components/CtaButton.astro";
import ScheduleCard from "@components/ScheduleCard.astro";
import { getScheduleData } from "@data/schedule";

const { events, speakerMap } = await getScheduleData();
---

<section id="schedule" class="section-sm text-center">
  <AnchorHeading anchor="schedule">Program</AnchorHeading>

  <CtaButton href="/compact-agenda/" class="px-6 py-2">Compact agenda 🔗</CtaButton>

  <p class="prose-content mt-4">
    Join us for a full day of Python talks, coffee breaks, lightning talks, and pizza.
  </p>

  {events.map((event, i) => {
    const speakers = (event.speakerIds ?? [])
      .map((id) => speakerMap[id])
      .filter(Boolean);
    return (
      <ScheduleCard
        event={event}
        speakers={speakers}
        invert={i % 2 === 0}
      />
    );
  })}
</section>
