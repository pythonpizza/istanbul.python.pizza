---
import Wave from "@components/Wave.astro";
import { socials } from "@data/socials";
---

<footer class="bg-primary">
  <Wave invert />
  <div class="flex flex-col items-center gap-6 pt-12 pb-24 md:pb-12">
    <div class="flex items-center justify-center gap-8">
      {socials.map((s) => (
        <a href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.name}>
          <img src={s.icon} alt={s.name} width="35" height="35" class="brightness-0 invert" />
        </a>
      ))}
    </div>
    <div class="flex items-center justify-center gap-6 text-white text-sm">
      <a href="/privacy-policy/" class="hover:underline underline-offset-4">Privacy Policy</a>
      <a href="/terms-of-service/" class="hover:underline underline-offset-4">Terms of Service</a>
    </div>
  </div>
</footer>
