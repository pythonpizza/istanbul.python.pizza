---
interface Props {
  url: string;
  icon: string;
  label: string;
  ariaLabel?: string;
  title?: string;
  size?: number;
}

const { url, icon, label, ariaLabel = label, title, size = 16 } = Astro.props;
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={ariaLabel}
  title={title}
  class="social-link"
>
  <img src={icon} alt={label} width={size} height={size} />
</a>
