---
import { getImage } from "astro:assets";
import Logo from "@components/Logo.astro";
import cityBg from "@assets/city.png";

const optimizedCityBg = await getImage({ src: cityBg, format: "avif", width: 1200 });

const menuItems = [
  { href: "/#about", label: "About 🍕" },
  { href: "/#sponsors", label: "Sponsors 💛" },
  { href: "/#schedule", label: "Program 📅" },
  { href: "/compact-agenda/", label: "Compact agenda 🔗" },
  { href: "/#organizers", label: "Organizers 👩🏻" },
  { href: "/#cfp", label: "CFP 🙋🏻‍♀️" },
  { href: "/#venue", label: "Venue 🏰" },
  { href: "/#coc", label: "CoC 💂" },
];
---

<header
  id="site-header"
  class="fixed top-3 md:top-4 left-0 w-full z-20 px-4 data-[menu-open=true]:z-30"
>
  <div class="glass-pill relative z-40 mx-auto flex w-fit max-w-full items-center gap-3 lg:gap-4 py-3 pl-4 pr-4">
    <Logo class="shrink-0 size-14" />

    <!-- Hamburger button (mobile/tablet) -->
    <button
      id="menu-toggle"
      type="button"
      aria-controls="mobile-menu"
      aria-expanded="false"
      aria-label="Open menu"
      class="lg:hidden flex h-12 w-12 items-center justify-center rounded-full text-white cursor-pointer"
    >
      <span id="menu-icon" class="relative w-7 h-0.5 rounded-full bg-white block transition-colors duration-200">
        <span class="absolute left-0 w-7 h-0.5 rounded-full bg-white block -top-2.5 transition-all duration-200"></span>
        <span class="absolute left-0 w-7 h-0.5 rounded-full bg-white block top-2.5 transition-all duration-200"></span>
      </span>
    </button>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-1">
      {menuItems.map(({ href, label }) => (
        <a href={href} class="nav-link text-center whitespace-nowrap">
          {label}
        </a>
      ))}
    </nav>
  </div>

  <!-- Mobile menu overlay -->
  <nav
    id="mobile-menu"
    aria-hidden="true"
    class="lg:hidden fixed inset-0 z-30 flex flex-col items-center justify-start overflow-y-auto px-8 pt-28 pb-10 text-white opacity-0 pointer-events-none -translate-y-2 transition-[opacity,transform] duration-200 ease-in-out bg-center bg-cover"
    style={`background-image: url(${optimizedCityBg.src})`}
  >
    <!-- Overlay tint -->
    <div class="absolute inset-0 bg-primary opacity-80 pointer-events-none"></div>

    <div class="relative z-10 mb-8">
      <Logo />
    </div>

    <ul class="relative z-10 flex flex-col items-center gap-2 list-none m-0 p-0">
      {menuItems.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="mobile-nav-link text-white text-2xl leading-tight py-2 block text-center hover:underline underline-offset-4"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  /* Hamburger → X, driven purely by the button's aria-expanded state */
  #menu-toggle[aria-expanded="true"] #menu-icon {
    background-color: transparent;
  }
  #menu-toggle[aria-expanded="true"] #menu-icon span:first-child {
    top: 0;
    transform: rotate(45deg);
  }
  #menu-toggle[aria-expanded="true"] #menu-icon span:last-child {
    top: 0;
    transform: rotate(-45deg);
  }
</style>

<script>
  const toggle = document.getElementById("menu-toggle")!;
  const menu = document.getElementById("mobile-menu")!;
  const header = document.getElementById("site-header")!;

  let open = false;

  function setOpen(next: boolean) {
    open = next;
    toggle.setAttribute("aria-expanded", String(next));
    toggle.setAttribute("aria-label", next ? "Close menu" : "Open menu");
    menu.setAttribute("aria-hidden", String(!next));
    menu.classList.toggle("opacity-0", !next);
    menu.classList.toggle("pointer-events-none", !next);
    menu.classList.toggle("-translate-y-2", !next);
    document.body.style.overflow = next ? "hidden" : "";
    header.dataset.menuOpen = String(next);
  }

  toggle.addEventListener("click", () => setOpen(!open));

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && open) setOpen(false);
  });

  // Close on nav link click
  menu.querySelectorAll(".mobile-nav-link").forEach((link) => {
    link.addEventListener("click", () => setOpen(false));
  });

  // Close when viewport goes desktop
  const mq = window.matchMedia("(min-width: 64rem)");
  mq.addEventListener("change", (e) => { if (e.matches) setOpen(false); });
</script>
